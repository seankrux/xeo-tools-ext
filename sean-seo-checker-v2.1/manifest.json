{
  "manifest_version": 3,
  "name": "Sean Guillermo AIO Tools - SEO Checker",
  "version": "2.0.0",
  "description": "Comprehensive SEO analysis with on-page highlighting, link checking, sitemap analysis, and real-time indexing verification",
  "author": "Sean Guillermo",
  "icons": {
    "16": "icons/icon-green-16.png",
    "32": "icons/icon-green-32.png",
    "48": "icons/icon-green-48.png",
    "128": "icons/icon-green-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-gray-16.png",
      "32": "icons/icon-gray-32.png",
      "48": "icons/icon-gray-48.png",
      "128": "icons/icon-gray-128.png"
    }
  },
  "background": {
    "service_worker": "scripts/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["scripts/content.js"],
      "css": ["styles/highlighter.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "options_page": "pages/settings.html"
}

